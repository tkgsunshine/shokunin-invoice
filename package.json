{
  "name": "shokunin-invoice",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=shokunin-invoice-production --r2=shokunin-invoice-bucket --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name shokunin-invoice",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "db:migrate:local": "wrangler d1 migrations apply shokunin-invoice-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply shokunin-invoice-production",
    "db:console:local": "wrangler d1 execute shokunin-invoice-production --local",
    "db:console:prod": "wrangler d1 execute shokunin-invoice-production"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.25.2",
    "@cloudflare/workers-types": "^4.20250705.0",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
